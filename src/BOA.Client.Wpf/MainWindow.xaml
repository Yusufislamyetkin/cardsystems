<Window x:Class="BOA.Client.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Emlak Katılım - BOA Temel Kart Operasyonları Portalı" 
        Height="850" Width="1350"
        WindowStartupLocation="CenterScreen"
        Background="#0b0f12"
        Foreground="#f3f4f6">

    <!-- WINDOW SEVİYESİNDE ÖZEL TASARIM VE STİL TANIMLARI -->
    <Window.Resources>
        <!-- Buton Stili -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#005A3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- İkincil/Vazgeç Buton Stili -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#1f2937"/>
            <Setter Property="Foreground" Value="#d1d5db"/>
        </Style>

        <!-- Form Elemanları Grid Stili -->
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9ca3af"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="Background" Value="#05080a"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <!-- 3 SATIRLI ANA YERLEŞİM GRİDİ -->
        <Grid.RowDefinitions>
            <!-- 1. Üst Menü / Logo Alnı -->
            <RowDefinition Height="65"/>
            <!-- 2. Orta İçerik Sütunları (Kart Listesi ve Detaylar) -->
            <RowDefinition Height="*"/>
            <!-- 3. Alt Canlı WCF & SQL Log İzleme Paneli -->
            <RowDefinition Height="240"/>
        </Grid.RowDefinitions>

        <!-- =====================================================================================
             1. SATIR: ÜST MENÜ VE LOGO ALANI
             ===================================================================================== -->
        <Border Grid.Row="0" BorderBrush="#1f2937" BorderThickness="0,0,0,1" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo ve Başlık -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🏛" FontSize="26" Foreground="#d4af37" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="emlak katılım" FontSize="18" FontWeight="Bold" Foreground="White" TextOptions.TextFormattingMode="Display"/>
                        <TextBlock Text="BOA Core Banking Framework Portal | WPF Masaüstü İstemcisi" FontSize="10" Foreground="#9ca3af"/>
                    </StackPanel>
                </StackPanel>

                <!-- Rol Simülasyonu -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <TextBlock Text="Simüle Edilen Rol:" VerticalAlignment="Center" Foreground="#9ca3af" Margin="0,0,8,0" FontSize="11"/>
                    <ComboBox x:Name="CmbUserRole" Width="200" Height="28" Background="#05080a" Foreground="White" VerticalAlignment="Center" SelectionChanged="CmbUserRole_SelectionChanged">
                        <ComboBoxItem Content="Şube Gişe Memuru (Teller)" Tag="MOCK_JWT_TELLER_TOKEN" IsSelected="True"/>
                        <ComboBoxItem Content="Kart Operasyon Yöneticisi (Admin)" Tag="MOCK_JWT_ADMIN_TOKEN"/>
                    </ComboBox>
                </StackPanel>

                <!-- Gün Sonu (EOD) Batch Tetikleme -->
                <Button Grid.Column="2" Content="🌙 Gün Sonu Batch Çalıştır" Style="{StaticResource ModernButton}" Background="#0f766e" Click="BtnRunEodBatch_Click" Margin="0,0,15,0" FontSize="11" Padding="8,4"/>

                <!-- Bağlantı Durumu -->
                <Border Grid.Column="3" VerticalAlignment="Center" Background="#111827" Padding="8,4" CornerRadius="4">
                    <StackPanel Orientation="Horizontal" ClipToBounds="True">
                        <Ellipse Width="8" Height="8" Fill="#10b981" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="WCF SOAP Connected" FontSize="11" Foreground="#9ca3af" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- =====================================================================================
             2. SATIR: ANA İÇERİK ALANI (ÇİFT SÜTUN)
             ===================================================================================== -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <!-- Sol Sütun: Filtreleme ve Kart Listesi -->
                <ColumnDefinition Width="420"/>
                <!-- Sağ Sütun: Kart Detay, Formlar ve Ekstre Grid'i -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SOL PANEL: KART SORGULAMA VE LİSTELEME -->
            <Border Grid.Column="0" Background="#161c23" CornerRadius="8" BorderBrush="#1f2937" BorderThickness="1" Padding="12" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Başlık -->
                        <RowDefinition Height="Auto"/> <!-- Arama Filtresi -->
                        <RowDefinition Height="*"/>    <!-- Liste -->
                    </Grid.RowDefinitions>

                    <!-- Başlık & Yeni Kart Açma Butonu -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Kayıtlı Kartlar" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="➕ Yeni Kart Tanımla" HorizontalAlignment="Right" Style="{StaticResource ModernButton}" Click="BtnNewCard_Click" FontSize="11" Padding="8,4"/>
                    </Grid>

                    <!-- Filtre Paneli -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtSearchHolder" Grid.Column="0" Style="{StaticResource FormInput}" Margin="0,0,5,0" Tag="Müşteri Adı Ara..." TextChanged="TxtSearchHolder_TextChanged" />
                        <ComboBox x:Name="CmbSearchType" Grid.Column="1" Background="#05080a" Foreground="White" BorderBrush="#374151" SelectionChanged="CmbSearchType_SelectionChanged" Height="30" VerticalAlignment="Top">
                            <ComboBoxItem Content="Tümü" IsSelected="True"/>
                            <ComboBoxItem Content="Banka (Debit)"/>
                            <ComboBoxItem Content="Kredi Kartı"/>
                        </ComboBox>
                    </Grid>

                    <!-- Liste Kutusu (ListBox) -->
                    <ListBox x:Name="LstCards" Grid.Row="2" Background="Transparent" BorderThickness="0" SelectionChanged="LstCards_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <!-- Listbox item tasarımı (Banka kartı yeşil vurgu, kredi kartı altın vurgu alacak şekilde) -->
                            <DataTemplate>
                                <Border BorderBrush="#1f2937" BorderThickness="1" CornerRadius="6" Background="#0f141a" Margin="0,0,0,8" Padding="10" Width="375" HorizontalAlignment="Stretch">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Kart tipi ikonu simülasyonu -->
                                        <TextBlock Grid.Column="0" Text="💳" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                        <!-- Kart bilgileri -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                            <TextBlock Text="{Binding MaskedCardNumber}" FontWeight="Bold" FontSize="12" Foreground="White"/>
                                            <TextBlock Text="{Binding CardHolderName}" FontSize="10" Foreground="#9ca3af"/>
                                        </StackPanel>

                                        <!-- Finansal tutar ve badge'ler -->
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" TextBlock.TextAlignment="Right">
                                            <TextBlock Text="{Binding Balance, StringFormat='₺{0:N2}'}" FontWeight="Bold" FontSize="12"/>
                                            <!-- Tip Badge'i -->
                                            <Border CornerRadius="3" Background="#1e3a8a" Padding="4,2" Margin="0,2,0,0" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding CardType}" FontSize="8" Foreground="#93c5fd" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- SAĞ PANEL: DETAYLAR VE OPERASYON PANELİ -->
            <Border Grid.Column="1" Background="#161c23" CornerRadius="8" BorderBrush="#1f2937" BorderThickness="1" Padding="15">
                <Grid>
                    <!-- KART SEÇİLMEDİĞİNDEKİ MESAJ -->
                    <StackPanel x:Name="PanelNoSelection" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="👆" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <TextBlock Text="Detayları Görüntülemek İçin Bir Kart Seçin" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Seçtiğiniz kartın 3D mockup görseli, limitleri ve hesap hareketleri burada yüklenecektir." FontSize="11" Foreground="#9ca3af" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- SEÇİLİ KART DETAYLARI -->
                    <Grid x:Name="PanelSelection" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <!-- Plastik Kart Görseli ve Hızlı Butonlar -->
                            <RowDefinition Height="Auto"/>
                            <!-- Harcama / Tutar Bilgileri -->
                            <RowDefinition Height="Auto"/>
                            <!-- Hareket Geçmişi DataGrid -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- ÜST SATIR: PLASTİK KART GÖRSELİ & OPERASYONLAR -->
                        <Grid Grid.Row="0" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="340"/> <!-- Plastik Kart -->
                                <ColumnDefinition Width="*"/>   <!-- Operasyonel İşlem Girişleri -->
                            </Grid.ColumnDefinitions>

                            <!-- Plastik Kart Mockup Tasarımı -->
                            <Border x:Name="VisualPlasticCard" Width="320" Height="190" CornerRadius="12" BorderThickness="1" BorderBrush="#26ffffff" HorizontalAlignment="Left" Padding="15">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0f1c18" Offset="0"/>
                                        <GradientStop Color="#005a3c" Offset="0.5"/>
                                        <GradientStop Color="#08211b" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Chip ve Banka Adı -->
                                    <Grid Grid.Row="0">
                                        <!-- Altın Çip görsel simülasyonu -->
                                        <Border Width="38" Height="28" Background="#b08d32" CornerRadius="4" HorizontalAlignment="Left"/>
                                        <TextBlock Text="emlak katılım" FontWeight="Bold" FontSize="14" Foreground="White" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <!-- Kart Numarası -->
                                    <TextBlock x:Name="TxtVisualCardNo" Grid.Row="1" Text="4355 20** **** 1234" FontFamily="Consolas" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Height="25"/>

                                    <!-- Kart Sahibi & Son Kullanma -->
                                    <Grid Grid.Row="2">
                                        <StackPanel HorizontalAlignment="Left">
                                            <TextBlock Text="KART SAHİBİ" FontSize="7" Foreground="#99ffffff"/>
                                            <TextBlock x:Name="TxtVisualHolder" Text="YUSUF BORA" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="SON KUL." FontSize="7" Foreground="#99ffffff"/>
                                            <TextBlock x:Name="TxtVisualExpiry" Text="12/31" FontSize="11" Foreground="White"/>
                                        </StackPanel>
                                        <!-- Visa / MC Simülasyonu -->
                                        <TextBlock x:Name="TxtVisualBrand" Text="VISA" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Hızlı İşlemler Paneli (Butonlar ve Küçük Formlar) -->
                            <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Kart Operasyonları" FontSize="12" FontWeight="SemiBold" Foreground="#9ca3af" Margin="0,0,0,10"/>
                                
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Content="⚙ Limit Düzenle" Grid.Row="0" Grid.Column="0" Style="{StaticResource ModernButton}" Background="#d97706" Click="BtnLimitUpdate_Click" Margin="0,0,5,5"/>
                                    <Button x:Name="BtnBlockCard" Grid.Row="0" Grid.Column="1" Content="🔒 Bloke Et" Style="{StaticResource ModernButton}" Background="#dc2626" Click="BtnBlock_Click" Margin="0,0,0,5"/>
                                    <Button Content="💸 İşlem Simüle Et" Grid.Row="1" Grid.Column="0" Style="{StaticResource ModernButton}" Background="#16a34a" Click="BtnSimulateTrans_Click" Margin="0,0,5,5"/>
                                    <Button Content="🔑 Şifre Doğrula" Grid.Row="1" Grid.Column="1" Style="{StaticResource ModernButton}" Background="#2563eb" Click="BtnVerifyPin_Click" Margin="0,0,0,5"/>
                                    <Button Content="🔖 Provizyon Al" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource ModernButton}" Background="#7c3aed" Click="BtnAuthorize_Click"/>
                                </Grid>

                                <!-- Seçili Kart Finansal Detayı -->
                                <Border Background="#0f141a" CornerRadius="6" Padding="10" Margin="0,15,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Toplam Kart Limiti" FontSize="10" Foreground="#9ca3af"/>
                                            <TextBlock x:Name="TxtDetailLimit" Text="₺15,000.00" FontSize="14" FontWeight="Bold"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock x:Name="TxtDetailBalanceLabel" Text="Kullanılabilir Bakiye" FontSize="10" Foreground="#9ca3af"/>
                                            <TextBlock x:Name="TxtDetailBalance" Text="₺5,000.00" FontSize="14" FontWeight="Bold" Foreground="#34d399"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="GL Hesap No" FontSize="10" Foreground="#9ca3af"/>
                                            <TextBlock x:Name="TxtDetailGlAccount" Text="GL-CARD-..." FontSize="11" FontWeight="Bold" Foreground="#60a5fa" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- ORTA SATIR: LİMİT VE BLOKAJ HIZLI GÜNCELLEME ALANLARI (Panel açıp kapatmalı) -->
                        <Grid Grid.Row="1" Margin="0,0,0,15">
                            
                            <!-- 1. LİMİT GÜNCELLEME FORMU (Varsayılan Gizli) -->
                            <Border x:Name="BorderLimitForm" Visibility="Collapsed" Background="#0f141a" BorderBrush="#d97706" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <TextBlock Text="Yeni Limit Değeri (₺):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBox x:Name="TxtNewLimitVal" Width="150" Style="{StaticResource FormInput}" Margin="0,0,15,0" VerticalAlignment="Center" Height="28"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="Vazgeç" Style="{StaticResource SecondaryButton}" Click="BtnCancelSubForm_Click" Margin="0,0,5,0" Height="28" Padding="10,2"/>
                                        <Button Content="Kaydet (SP_UPDATE_LIMIT)" Style="{StaticResource ModernButton}" Background="#d97706" Click="BtnSubmitLimit_Click" Height="28" Padding="10,2"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 2. DURUM DEĞİŞİKLİĞİ VE BLOKAJ FORMU (Varsayılan Gizli) -->
                            <Border x:Name="BorderStatusForm" Visibility="Collapsed" Background="#0f141a" BorderBrush="#dc2626" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="Yeni Durum:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <ComboBox x:Name="CmbNewStatus" Width="140" Background="#05080a" Foreground="White" Height="28" VerticalAlignment="Center">
                                                <ComboBoxItem Content="Aktif" Tag="1"/>
                                                <ComboBoxItem Content="Bloke" Tag="2"/>
                                                <ComboBoxItem Content="İptal" Tag="3"/>
                                            </ComboBox>
                                            <TextBlock Text="Gerekçe (Reason):" VerticalAlignment="Center" Margin="15,0,10,0"/>
                                            <TextBox x:Name="TxtStatusReason" Width="200" Style="{StaticResource FormInput}" Margin="0,0,15,0" VerticalAlignment="Center" Height="28"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="Vazgeç" Style="{StaticResource SecondaryButton}" Click="BtnCancelSubForm_Click" Margin="0,0,5,0" Height="28" Padding="10,2"/>
                                            <Button Content="Değiştir (SP_SET_STATUS)" Style="{StaticResource ModernButton}" Background="#dc2626" Click="BtnSubmitStatus_Click" Height="28" Padding="10,2"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 3. İŞLEM SİMÜLASYON FORMU (Varsayılan Gizli) -->
                            <Border x:Name="BorderSimulateForm" Visibility="Collapsed" Background="#0f141a" BorderBrush="#16a34a" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="Tür:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <ComboBox x:Name="CmbTransType" Width="130" Background="#05080a" Foreground="White" Height="28" VerticalAlignment="Center" Margin="0,0,10,0">
                                                <ComboBoxItem Content="Alışveriş [-]" Tag="1" IsSelected="True"/>
                                                <ComboBoxItem Content="ATM Para Çekme [-]" Tag="2"/>
                                                <ComboBoxItem Content="ATM Para Yatırma [+]" Tag="3"/>
                                            </ComboBox>
                                            <TextBlock Text="Tutar (₺):" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox x:Name="TxtTransAmount" Width="90" Style="{StaticResource FormInput}" Margin="0,0,10,0" VerticalAlignment="Center" Height="28"/>
                                            <TextBlock Text="Şifre (PIN):" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <PasswordBox x:Name="TxtTransPin" Width="55" MaxLength="4" Background="#05080a" Foreground="White" BorderBrush="#374151" Padding="6" Margin="0,0,10,0" VerticalAlignment="Center" Height="28" Password="1234"/>
                                            <TextBlock Text="Açıklama:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox x:Name="TxtTransDesc" Width="150" Style="{StaticResource FormInput}" Margin="0,0,15,0" VerticalAlignment="Center" Height="28"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="İptal" Style="{StaticResource SecondaryButton}" Click="BtnCancelSubForm_Click" Margin="0,0,5,0" Height="28" Padding="10,2"/>
                                            <Button Content="Gönder (SP_TRANSACTION)" Style="{StaticResource ModernButton}" Background="#16a34a" Click="BtnSubmitTrans_Click" Height="28" Padding="10,2"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 4. YENİ KART TANIMLAMA FORMU (Varsayılan Gizli) -->
                            <Border x:Name="BorderNewCardForm" Visibility="Collapsed" Background="#0f141a" BorderBrush="#005A3C" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="Müşteri Adı:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox x:Name="TxtNewCardHolder" Width="130" Style="{StaticResource FormInput}" Margin="0,0,10,0" VerticalAlignment="Center" Height="28" CharacterCasing="Upper"/>

                                            <TextBlock Text="TCKN:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox x:Name="TxtNewCardNationalId" Width="90" MaxLength="11" Style="{StaticResource FormInput}" Margin="0,0,10,0" VerticalAlignment="Center" Height="28"/>

                                            <TextBlock Text="Tür:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <ComboBox x:Name="CmbNewCardType" Width="100" Background="#05080a" Foreground="White" Height="28" VerticalAlignment="Center" Margin="0,0,10,0" SelectionChanged="CmbNewCardType_SelectionChanged">
                                                <ComboBoxItem Content="Banka (Debit)" Tag="1" IsSelected="True"/>
                                                <ComboBoxItem Content="Kredi Kartı" Tag="2"/>
                                            </ComboBox>
                                            
                                            <TextBlock x:Name="LblNewCardLimit" Text="Limit (₺):" VerticalAlignment="Center" Margin="0,0,5,0" Visibility="Collapsed"/>
                                            <TextBox x:Name="TxtNewCardLimit" Width="80" Style="{StaticResource FormInput}" Margin="0,0,10,0" VerticalAlignment="Center" Height="28" Text="0" Visibility="Collapsed"/>
                                            
                                            <TextBlock x:Name="LblNewCardBalance" Text="Bakiye (₺):" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox x:Name="TxtNewCardBalance" Width="80" Style="{StaticResource FormInput}" Margin="0,0,10,0" VerticalAlignment="Center" Height="28" Text="1000"/>

                                            <TextBlock Text="Şifre (PIN):" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <PasswordBox x:Name="TxtNewCardPin" Width="55" MaxLength="4" Background="#05080a" Foreground="White" BorderBrush="#374151" Padding="6" Margin="0,0,15,0" VerticalAlignment="Center" Height="28" Password="1234"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="İptal" Style="{StaticResource SecondaryButton}" Click="BtnCancelSubForm_Click" Margin="0,0,5,0" Height="28" Padding="10,2"/>
                                            <Button Content="Kart Aç (CreateCard SOAP)" Style="{StaticResource ModernButton}" Background="#005A3C" Click="BtnSubmitNewCard_Click" Height="28" Padding="10,2"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 5. ŞİFRE DOĞRULAMA FORMU (Varsayılan Gizli) -->
                            <Border x:Name="BorderVerifyPinForm" Visibility="Collapsed" Background="#0f141a" BorderBrush="#2563eb" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="Doğrulanacak Şifre (PIN):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <PasswordBox x:Name="TxtVerifyPinVal" Width="100" MaxLength="4" Background="#05080a" Foreground="White" BorderBrush="#374151" Padding="6" Margin="0,0,15,0" VerticalAlignment="Center" Height="28" Password="1234"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="Vazgeç" Style="{StaticResource SecondaryButton}" Click="BtnCancelSubForm_Click" Margin="0,0,5,0" Height="28" Padding="10,2"/>
                                            <Button Content="Doğrula (VerifyPin SOAP)" Style="{StaticResource ModernButton}" Background="#2563eb" Click="BtnSubmitVerifyPin_Click" Height="28" Padding="10,2"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 6. PROVİZYON ALMA FORMU (Varsayılan Gizli) -->
                            <Border x:Name="BorderAuthorizeForm" Visibility="Collapsed" Background="#0f141a" BorderBrush="#7c3aed" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="Tutar (₺):" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox x:Name="TxtAuthAmount" Width="90" Style="{StaticResource FormInput}" Margin="0,0,10,0" VerticalAlignment="Center" Height="28"/>
                                            <TextBlock Text="Şifre (PIN):" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <PasswordBox x:Name="TxtAuthPin" Width="55" MaxLength="4" Background="#05080a" Foreground="White" BorderBrush="#374151" Padding="6" Margin="0,0,10,0" VerticalAlignment="Center" Height="28" Password="1234"/>
                                            <TextBlock Text="Üye İş Yeri:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox x:Name="TxtAuthMerchant" Width="100" Style="{StaticResource FormInput}" Margin="0,0,10,0" VerticalAlignment="Center" Height="28" Text="MIGROS-1234"/>
                                            <TextBlock Text="MCC:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox x:Name="TxtAuthMcc" Width="60" Style="{StaticResource FormInput}" Margin="0,0,15,0" VerticalAlignment="Center" Height="28" Text="5411"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="İptal" Style="{StaticResource SecondaryButton}" Click="BtnCancelSubForm_Click" Margin="0,0,5,0" Height="28" Padding="10,2"/>
                                            <Button Content="Provizyon Al (Authorize)" Style="{StaticResource ModernButton}" Background="#7c3aed" Click="BtnSubmitAuthorize_Click" Height="28" Padding="10,2"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </Grid>

                        <!-- ALT SATIR: HAREKET GEÇMİŞİ (DATAGRID) -->
                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Kart Ekstre Hareketleri" FontSize="11" FontWeight="SemiBold" Foreground="#9ca3af" Margin="0,0,0,5"/>
                            <DataGrid x:Name="DgTransactions" Grid.Row="1" Background="#0f141a" BorderThickness="1" BorderBrush="#1f2937" 
                                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" 
                                      HorizontalGridLinesBrush="#1f2937" AlternatingRowBackground="#161c23" RowBackground="#0f141a" Foreground="White">
                                <DataGrid.Resources>
                                    <!-- Header Stili -->
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#1f2937"/>
                                        <Setter Property="Foreground" Value="#d1d5db"/>
                                        <Setter Property="Padding" Value="8,5"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                    <!-- Cell Stili -->
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Padding" Value="8"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tarih" Binding="{Binding TransactionDate, StringFormat='dd.MM.yyyy HH:mm'}" Width="150"/>
                                    <DataGridTextColumn Header="Açıklama" Binding="{Binding Description}" Width="*"/>
                                    <DataGridTextColumn Header="İşlem Tipi" Binding="{Binding TransactionType}" Width="100"/>
                                    <DataGridTextColumn Header="Tutar" Binding="{Binding Amount, StringFormat='₺{0:N2}'}" Width="120"/>
                                    <DataGridTextColumn Header="Referans No" Binding="{Binding ReferenceNumber}" Width="150"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>

                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- =====================================================================================
             3. SATIR: GERÇEK ZAMANLI WCF & SQL LOG İZLEME PANELİ (TRACER)
             ===================================================================================== -->
        <Border Grid.Row="2" Background="#161c23" CornerRadius="8" BorderBrush="#1f2937" BorderThickness="1" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28"/> <!-- Panel Başlığı -->
                    <RowDefinition Height="*"/>  <!-- Log Alanları -->
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,5">
                    <TextBlock Text="🤖 BOA Canlı WCF SOAP ve SQL Stored Procedure İzleyici (Tracer)" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Content="🗑 Logları Temizle" HorizontalAlignment="Right" Style="{StaticResource SecondaryButton}" Click="BtnClearLogs_Click" FontSize="10" Padding="8,2"/>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- WCF SOAP Logs -->
                    <Grid Grid.Column="0" Margin="0,0,5,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="WCF SOAP XML Zarfı (BasicHttpBinding)" FontSize="9" Foreground="#a78bfa" Margin="0,0,0,2"/>
                        <TextBox x:Name="TxtWcfLogs" Grid.Row="1" Background="#05080a" Foreground="#a78bfa" FontFamily="Consolas" FontSize="10" 
                                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" BorderBrush="#1f2937"/>
                    </Grid>

                    <!-- SQL SP Logs -->
                    <Grid Grid.Column="1" Margin="5,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Oracle Database Stored Procedure Parametre &amp; Çalışma Süresi (PL/SQL)" FontSize="9" Foreground="#fde047" Margin="0,0,0,2"/>
                        <TextBox x:Name="TxtSqlLogs" Grid.Row="1" Background="#05080a" Foreground="#fde047" FontFamily="Consolas" FontSize="10" 
                                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" BorderBrush="#1f2937"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

    </Grid>
</Window>
